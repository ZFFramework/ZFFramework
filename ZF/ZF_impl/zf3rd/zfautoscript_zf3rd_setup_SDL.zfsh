cmake ../../../_repo/SDL_mixer -DCMAKE_INSTALL_PREFIX="<ZF_ROOT_PATH>\_tmp\SDL" -DCMAKE_BUILD_TYPE=Release -DSDL2MIXER_FLAC=OFF -DSDL2MIXER_MIDI=OFF -DSDL2MIXER_MOD=OFF -DSDL2MIXER_OPUS=OFF -DSDL2MIXER_WAVPACK=OFF
make -j4
make install <ZF_IGNORE_OUTPUT>
cd "<ZF_WORK_DIR>"


