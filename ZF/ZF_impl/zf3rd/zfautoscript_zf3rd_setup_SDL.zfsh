cmake --version
<ZF_IF_FAILED_BEGIN>
    <ZF_EXIT_SUCCESS>
<ZF_IF_FAILED_END>


<ZF_COMMENT> SDL
<ZF_SH> "<ZF_ROOT_PATH>\tools\common\git_check.<ZF_SH_EXT>" "https://github.com/libsdl-org/SDL" SDL2 "<ZF_WORK_DIR>\_repo\SDL"
<ZF_SH> "<ZF_ROOT_PATH>\tools\common\zfsh\mkdir.<ZF_SH_EXT>" "<ZF_WORK_DIR>\_tmp\SDL\build_SDL"
cd "<ZF_WORK_DIR>\_tmp\SDL\build_SDL"
cmake ../../../_repo/SDL -DCMAKE_INSTALL_PREFIX="<ZF_ROOT_PATH>\_tmp\SDL" -DCMAKE_BUILD_TYPE=Release
make -j4
make install <ZF_IGNORE_OUTPUT>
cd "<ZF_WORK_DIR>"


